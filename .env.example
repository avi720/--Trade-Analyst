# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres?pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres

# Encryption key for IBKR Flex Token (32-byte hex)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
FLEX_TOKEN_ENCRYPTION_KEY=

# External APIs
MASSIVE_API_KEY=
GEMINI_API_KEY=

# Cron authentication — Bearer token expected by /api/cron/* endpoints.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=

# Canonical app URL — used server-side by getBaseUrl() to build redirect/callback URLs.
# Set in Vercel dashboard (e.g. https://your-app.vercel.app); omit locally.
SITE_URL=https://your-app.vercel.app

# AI Excel import — OPTIONAL near-instant worker trigger. When both are set, the
# upload route fires a GitHub repository_dispatch so the worker runs within
# seconds; otherwise the '*/5 * * * *' schedule in ai-import-worker.yml picks the
# job up. Token = fine-grained PAT with "Contents: read" + repo access (dispatch).
# Repo = "owner/repo". Both server-only. Omit to rely on the schedule alone.
AI_IMPORT_DISPATCH_TOKEN=
AI_IMPORT_DISPATCH_REPO=

# Sentry — error tracking. DSN is browser-safe (public).
# Get from Sentry → Settings → Projects → Client Keys (DSN).
NEXT_PUBLIC_SENTRY_DSN=

# Sentry auth token — required only for source-map upload during build.
# Get from Sentry → Settings → Auth Tokens (scope: project:releases, org:read).
SENTRY_AUTH_TOKEN=

# PostHog — analytics + signup funnel. Project API key is browser-safe (public).
# Get from PostHog → Settings → Project → Project API key.
NEXT_PUBLIC_POSTHOG_KEY=
# Default to US cloud; switch to https://eu.i.posthog.com if project is on EU cloud.
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Lemon Squeezy — billing (merchant of record).
# Get from https://app.lemonsqueezy.com → Settings → API → API Keys.
LEMONSQUEEZY_API_KEY=
# Store ID: visible in dashboard URL (app.lemonsqueezy.com/stores/<id>).
LEMONSQUEEZY_STORE_ID=
# Variant IDs for the Pro product. Get from Products → Pro → Variants.
LEMONSQUEEZY_VARIANT_ID_MONTHLY=
LEMONSQUEEZY_VARIANT_ID_ANNUAL=
# Webhook signing secret: Settings → Webhooks → Signing secret.
LEMONSQUEEZY_WEBHOOK_SECRET=
# Launch promo discount CODES (optional — omit after promo ends). Note: use the
# discount CODE (e.g. "IYNDCZNQ"), not the numeric ID — LS checkout API expects
# checkout_data.discount_code. Create in Discounts → New Discount. Monthly:
# $5 off, 3 repeating months. Annual: $50 off, once.
LEMONSQUEEZY_DISCOUNT_CODE_LAUNCH_MONTHLY=
LEMONSQUEEZY_DISCOUNT_CODE_LAUNCH_ANNUAL=
