# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres?pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres

# Encryption key for IBKR Flex Token (32-byte hex)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
FLEX_TOKEN_ENCRYPTION_KEY=

# External APIs
MASSIVE_API_KEY=
GEMINI_API_KEY=

# App URL (for Render deployment)
NEXTAUTH_URL=https://your-app.onrender.com
