# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres?pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres

# Encryption key for IBKR Flex Token (32-byte hex)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
FLEX_TOKEN_ENCRYPTION_KEY=

# External APIs
MASSIVE_API_KEY=
GEMINI_API_KEY=

# Canonical app URL — used server-side by getBaseUrl() to build redirect/callback URLs.
# Set in Vercel dashboard (e.g. https://your-app.vercel.app); omit locally.
SITE_URL=https://your-app.vercel.app

# Sentry — error tracking. DSN is browser-safe (public).
# Get from Sentry → Settings → Projects → Client Keys (DSN).
NEXT_PUBLIC_SENTRY_DSN=

# Sentry auth token — required only for source-map upload during build.
# Get from Sentry → Settings → Auth Tokens (scope: project:releases, org:read).
SENTRY_AUTH_TOKEN=
